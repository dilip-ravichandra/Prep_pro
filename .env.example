# InterviewSimPro environment variables
# Backend uses these values via application.properties placeholders.

# JWT
JWT_SECRET=InterviewSimProJwtSecretKey_2026_SuperLong_AtLeast32Chars

# Frontend URL used in password reset links
FRONTEND_URL=http://localhost:3000

# Groq AI
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
WHISPER_MODEL=whisper-large-v3-turbo

# Video interview processing
VIDEO_UPLOAD_DIR=uploads/videos
AUDIO_UPLOAD_DIR=uploads/audio
FFMPEG_PATH=ffmpeg

# SMTP Email (for forgot password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_gmail_app_password

# Dedicated Admin Auth
ADMIN_AUTH_EMAIL=admin@example.com
ADMIN_AUTH_PASSWORD=change_this_password

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/interviewsim
MONGODB_DATABASE=interviewsim
